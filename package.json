{
  "name": "create-cf-token",
  "version": "1.1.6",
  "description": "CLI for creating Cloudflare API tokens with interactive, guided prompts",
  "keywords": [
    "api-token",
    "cli",
    "cloudflare",
    "create-token"
  ],
  "homepage": "https://github.com/mynameistito/create-cf-token#readme",
  "bugs": {
    "url": "https://github.com/mynameistito/create-cf-token/issues"
  },
  "license": "MIT",
  "author": "Tito <github@mynameistito.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mynameistito/create-cf-token.git"
  },
  "bin": {
    "create-cf-token": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "assets/automation",
    "assets/token-spec.schema.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./api": {
      "types": "./dist/api.d.mts",
      "import": "./dist/api.mjs",
      "default": "./dist/api.mjs"
    },
    "./errors": {
      "types": "./dist/errors.d.mts",
      "import": "./dist/errors.mjs",
      "default": "./dist/errors.mjs"
    },
    "./permissions": {
      "types": "./dist/permissions.d.mts",
      "import": "./dist/permissions.mjs",
      "default": "./dist/permissions.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts"
    },
    "./create": {
      "types": "./dist/create.d.mts",
      "import": "./dist/create.mjs",
      "default": "./dist/create.mjs"
    },
    "./spec": {
      "types": "./dist/spec.d.mts",
      "import": "./dist/spec.mjs",
      "default": "./dist/spec.mjs"
    },
    "./scope-spec": {
      "types": "./dist/scope-spec.d.mts",
      "import": "./dist/scope-spec.mjs",
      "default": "./dist/scope-spec.mjs"
    },
    "./policies": {
      "types": "./dist/policies.d.mts",
      "import": "./dist/policies.mjs",
      "default": "./dist/policies.mjs"
    }
  },
  "scripts": {
    "audit": "bun audit",
    "audit:npm": "npm install --package-lock-only --ignore-scripts && npm audit --audit-level=high",
    "build": "tsdown",
    "bump": "bun update --latest && bun add -d @types/node@~22.19.15",
    "changeset": "changeset",
    "changeset-add": "bun run ./scripts/changeset-add.ts",
    "check": "ultracite check",
    "dev": "bun src/cli.ts",
    "fix": "ultracite fix",
    "knip": "bunx knip@6.18.0",
    "prepare": "lefthook install || true",
    "prepublishOnly": "bun run build && bun run sync-skill",
    "dryrun:deno": "deno task publish:dry-run",
    "release": "bun run build && changeset publish --provenance",
    "security:scan": "bun run build && bun test __tests__/security.test.ts",
    "start": "bun src/cli.ts",
    "sync-skill": "bun run ./scripts/sync-skill.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:e2e:node": "bun run build && bun test node.e2e",
    "test:node": "bun run test:e2e:node",
    "typecheck": "tsgo --noEmit",
    "version-packages": "changeset version",
    "watch": "bun --watch src/cli.ts"
  },
  "dependencies": {
    "@clack/core": "^1.4.2",
    "@clack/prompts": "^1.6.0",
    "better-result": "^2.9.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "~22.19.15",
    "@typescript/native-preview": "^7.0.0-dev.20260623.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "ultracite": "^7.8.3",
    "unrun": "^0.3.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "defu": "^6.1.5",
    "js-yaml": "^4.2.0"
  },
  "engines": {
    "node": ">=22"
  }
}
