{
  "name": "create-cf-token",
  "version": "1.0.0",
  "description": "CLI for creating Cloudflare API tokens with interactive, guided prompts",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "create-cf-token": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./api": {
      "types": "./dist/api.d.mts",
      "import": "./dist/api.mjs",
      "default": "./dist/api.mjs"
    },
    "./errors": {
      "types": "./dist/errors.d.mts",
      "import": "./dist/errors.mjs",
      "default": "./dist/errors.mjs"
    },
    "./permissions": {
      "types": "./dist/permissions.d.mts",
      "import": "./dist/permissions.mjs",
      "default": "./dist/permissions.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cloudflare",
    "api-token",
    "cli",
    "create-token"
  ],
  "author": "Tito <github@mynameistito.com>",
  "homepage": "https://github.com/mynameistito/create-cf-token#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mynameistito/create-cf-token.git"
  },
  "bugs": {
    "url": "https://github.com/mynameistito/create-cf-token/issues"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "start": "bun src/cli.ts",
    "watch": "bun --watch src/cli.ts",
    "build": "tsdown",
    "bump": "bun update --latest && bun add -d @types/node@~22.15.0",
    "typecheck": "tsgo --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install || true",
    "prepublishOnly": "bun run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish --provenance"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@types/node": "~25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "lefthook": "^2.1.4",
    "tsdown": "^0.21.7",
    "ultracite": "7.4.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "better-result": "^2.7.0"
  }
}
