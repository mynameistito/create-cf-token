{
  "name": "create-cf-token",
  "version": "0.1.0",
  "description": "CLI for creating Cloudflare API tokens with interactive, guided prompts",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "create-cf-token": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cloudflare",
    "api-token",
    "cli",
    "create-token"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install || true",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "latest",
    "lefthook": "^2.1.4",
    "ultracite": "7.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "better-result": "^2.7.0"
  }
}
