{
  "name": "create-cf-token",
  "version": "0.1.0",
  "description": "CLI for creating Cloudflare API tokens with interactive, guided prompts",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "create-cf-token": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cloudflare",
    "api-token",
    "cli",
    "create-token"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mynameistito/create-cf-token.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "watch": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "typecheck": "tsgo --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install || true",
    "prepublishOnly": "bun run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish --provenance"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@types/node": "~22.15.0",
    "@typescript/native-preview": "^7.0.0-dev.20260330.1",
    "lefthook": "^2.1.4",
    "ultracite": "7.4.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "better-result": "^2.7.0"
  }
}
