{
  "name": "@mynameistito/create-cf-token",
  "version": "1.1.6",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api.ts",
    "./create": "./src/create.ts",
    "./errors": "./src/errors.ts",
    "./permissions": "./src/permissions.ts",
    "./policies": "./src/policies.ts",
    "./scope-spec": "./src/scope-spec.ts",
    "./spec": "./src/spec.ts",
    "./types": "./src/types.ts"
  },
  "imports": {
    "#src/": "./src/",
    "@clack/core": "npm:@clack/core@^1.4.2",
    "@clack/prompts": "npm:@clack/prompts@^1.6.0",
    "better-result": "npm:better-result@^2.9.2"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["ESNext", "deno.window"],
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "exclude": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.e2e.ts",
    "dist/**",
    "opensrc/**"
  ],
  "tasks": {
    "publish:dry-run": "deno publish --dry-run",
    "pack:dry-run": "deno pack --dry-run"
  },
  "publish": {
    "exclude": [
      "**/__tests__/**",
      "**/*.test.ts",
      ".changeset/**",
      ".claude/**",
      ".env.example",
      ".github/**",
      ".vscode/**",
      ".zed/**",
      "AGENTS.md",
      "CHANGELOG.md",
      "CLAUDE.md",
      "CODE_OF_CONDUCT.md",
      "CONTRIBUTING.md",
      "SECURITY.md",
      "assets/prompt.md",
      "assets/social-preview.html",
      "assets/social-preview.png",
      "assets/social-preview/**",
      "bun.lock",
      "bunfig.toml",
      "deno.lock",
      "dist/**",
      "opensrc/**",
      "oxfmt.config.ts",
      "oxlint.config.ts",
      "plans/**",
      "scripts/**",
      "skill/**",
      "src/AGENTS.md",
      "src/CLAUDE.md",
      "**/*.e2e.ts",
      "tsconfig.json",
      "tsdown.config.ts",
      "knip.json",
      "lefthook.yml",
      "biome.jsonc",
      "oxlint.json",
      ".oxfmtrc.jsonc"
    ]
  }
}
